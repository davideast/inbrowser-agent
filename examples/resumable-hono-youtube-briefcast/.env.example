# memory lets the UI run without Firebase credentials. Use rtdb for durable jobs.
BRIEFCAST_STORE=memory
# Explicit rtdb mode fails fast by default. Set to memory to keep demos running.
BRIEFCAST_RTDB_FALLBACK=off
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Kore
RTDB_URL=https://your-project-default-rtdb.firebaseio.com
SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json
BRIEFCAST_PORT=8787
